{
  "name": "incenva-scraper-service",
  "version": "1.0.0",
  "description": "Go-based incentive scraper service for Incenva Rebate Finder",
  "private": true,
  "type": "module",
  "scripts": {
    "go:deps": "node scripts/go-mod.mjs download",
    "go:tidy": "node scripts/go-mod.mjs tidy",
    "go:verify": "node scripts/go-mod.mjs verify",
    "run": "node scripts/run.mjs",
    "run:all": "node scripts/run.mjs all",
    "run:dsireusa": "node scripts/run.mjs dsireusa",
    "run:rewiring_america": "node scripts/run.mjs rewiring_america",
    "run:energy_star": "node scripts/run.mjs energy_star",
    "run:con_edison": "node scripts/run.mjs con_edison",
    "run:pnm": "node scripts/run.mjs pnm",
    "run:xcel_energy": "node scripts/run.mjs xcel_energy",
    "pdf": "node scripts/run-pdf.mjs",
    "staging:stats": "node scripts/run-staging-stats.mjs",
    "scraper:promote": "node scripts/run-promoter.mjs",
    "scraper:promote:dry": "node scripts/run-promoter.mjs --dry-run",

    "backfill:zipcode-sources": "psql \"$DATABASE_URL\" -f scripts/backfill-zipcode-sources.sql"
  },
  "engines": {
    "node": ">=18"
  }
}