# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Shared with the consumer app (same DB).
DATABASE_URL=postgresql://USER:PASS@localhost:5432/rebate_finder

# ── Scraper behaviour ─────────────────────────────────────────────────────────
# true  → run all scrapers once and exit (CI / manual refresh)
# false → run on cron schedule (long-running server mode)
RUN_ONCE=false

# robfig/cron schedule: "@every 6h", "0 2 * * *" (daily 2 AM), "@daily"
SCRAPER_INTERVAL=@every 6h

# Written to scraper_version column on every upsert — bump when logic changes.
SCRAPER_VERSION=1.0

# ── Logging ───────────────────────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info

# json (default, structured) | console (human-readable lines)
LOG_FORMAT=json

# ── Data sources ──────────────────────────────────────────────────────────────
DSIREUSA_BASE_URL=https://programs.dsireusa.org/api/v1/programs

# Required — get a free key at https://www.rewiringamerica.org/api
REWIRING_AMERICA_API_KEY=

REWIRING_AMERICA_BASE_URL=https://api.rewiringamerica.org/api/v1/calculator

# ── ZIP coverage ─────────────────────────────────────────────────────────────
# uszips.csv is auto-detected at data/uszips.csv relative to the binary.
# Both scrapers will use ALL ~33k ZIPs from the file by default.
#
# Set DSIRE_ZIPS_PER_STATE / ENERGY_STAR_ZIPS_PER_STATE to limit ZIPs per state
# (useful for faster development runs).  0 = no limit (default, uses all ZIPs).
# Example: DSIRE_ZIPS_PER_STATE=1 → 51 ZIPs, one per state (~5 min run).
#
# DSIRE_ZIPS_PER_STATE=0
# ENERGY_STAR_ZIPS_PER_STATE=0

# Energy Star rebate-finder API
ENERGY_STAR_API_BASE_URL=https://www.energystar.gov
# Milliseconds to sleep between page requests per ZIP (polite delay)
ENERGY_STAR_PAGE_DELAY_MS=500
# Max goroutines fetching pages concurrently per ZIP
ENERGY_STAR_MAX_CONCURRENCY=3

# ── PDF scraper — Consumers Energy ───────────────────────────────────────────
# Paths to the local PDF files used by cmd/pdf-scraper.
# Can also be supplied at runtime via --catalog / --application CLI flags
# (CLI flags take highest priority).
CONSUMERS_ENERGY_CATALOG_PDF=/path/to/Consumers_Energy_Incentive_Catalog_1.pdf
CONSUMERS_ENERGY_APPLICATION_PDF=/path/to/Incentive-Application.pdf

# ── Advanced / optional ───────────────────────────────────────────────────────
# Set to an absolute path to load a specific .env file instead of the
# default walk-up search (useful for Docker or custom CI setups).
# DOTENV_PATH=/etc/incenva/scraper.env

# Restrict a single run to one source without changing code.
# Valid values: dsireusa | rewiring_america | energy_star
# SOURCE=dsireusa
