# ── Database ──────────────────────────────────────────────────────────────────
# Single-tenant mode: same DB as the consumer app (staging + live in one DB).
# Multi-tenant mode (fly.io): the scraper's OWN staging DB on fly.io Postgres.
DATABASE_URL=postgresql://USER:PASS@localhost:5432/rebate_finder

# ── Multi-tenant config ───────────────────────────────────────────────────────
# Path to the tenant config file (relative to the working directory or absolute).
# Set to an empty string to disable multi-tenant mode.
# Default: config/tenants.json
# TENANTS_FILE=config/tenants.json

# Per-tenant DB URLs — one env var per active tenant.
# Naming convention: TENANT_<ID_UPPER>_DB_URL
# These are set as fly.io secrets in production (not stored in .env).
# TENANT_ACME_DB_URL=postgresql://USER:PASS@host:5432/acme_rebate_finder
# TENANT_BETA_DB_URL=postgresql://USER:PASS@host:5432/beta_rebate_finder

# ── Scraper behaviour ─────────────────────────────────────────────────────────
# true  → run all scrapers once and exit (CI / manual refresh)
# false → run on cron schedule (long-running server mode)
RUN_ONCE=false

# robfig/cron schedule: "@every 6h", "0 2 * * *" (daily 2 AM), "@daily"
SCRAPER_INTERVAL=@every 6h

# Written to scraper_version column on every upsert — bump when logic changes.
SCRAPER_VERSION=1.0

# ── Logging ───────────────────────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info

# json (default, structured) | console (human-readable lines)
LOG_FORMAT=json

# ── Data sources ──────────────────────────────────────────────────────────────
DSIREUSA_BASE_URL=https://programs.dsireusa.org/api/v1/programs

# Required — get a free key at https://www.rewiringamerica.org/api
REWIRING_AMERICA_API_KEY=

REWIRING_AMERICA_BASE_URL=https://api.rewiringamerica.org/api/v1/calculator

# ── Energy Star ───────────────────────────────────────────────────────────────
ENERGY_STAR_API_BASE_URL=https://www.energystar.gov

# ── Global scraper tuning ─────────────────────────────────────────────────────
# Milliseconds to sleep between successive HTTP requests within a scraper.
PAGE_DELAY_MS=500
# Max parallel goroutines for scrapers that support concurrent fetching.
MAX_CONCURRENCY=3

# ── Advanced / optional ───────────────────────────────────────────────────────
# Set to an absolute path to load a specific .env file instead of the
# default walk-up search (useful for Docker or custom CI setups).
# DOTENV_PATH=/etc/incenva/scraper.env

# Restrict a single run to one source without changing code.
# Valid values: dsireusa | rewiring_america | energy_star
# SOURCE=dsireusa

# ── Data quality evaluator (cmd/evaluator) ────────────────────────────────────
# GPT-4o is used to re-extract fields from stored raw responses and diff them
# against what the scraper actually stored.  Get a key at platform.openai.com.
OPENAI_API_KEY=
